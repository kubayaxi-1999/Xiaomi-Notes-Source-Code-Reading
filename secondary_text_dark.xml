<!-- 颜色状态选择器（ColorStateList），始终返回半透明黑色 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 未指定任何状态（如按下、选中、聚焦等），默认且唯一使用的颜色 -->
    <!-- 颜色值 #50000000 表示 50% 透明度的黑色（ARGB 格式：A=0x50, R=0x00, G=0x00, B=0x00） -->
    <item android:color="#50000000" />
</selector>