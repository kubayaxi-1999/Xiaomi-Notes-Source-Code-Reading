<!-- 垂直方向的线性布局，作为对话框的主容器，宽度和高度均填满父容器 -->
<LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:orientation="vertical"
        xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 对话框标题文本框：使用中等字体样式，单行显示，超出部分显示省略号，文字居中 -->
    <TextView
        android:id="@+id/account_dialog_title"
        style="?android:attr/textAppearanceMedium"
        android:singleLine="true"
        android:ellipsize="end"
        android:gravity="center"
        android:layout_marginTop="-2.7dip"
        android:layout_marginBottom="-2.7dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"/>

    <!-- 对话框副标题文本框：宽度填满父容器，上下边距适当，文字居中 -->
    <TextView
        android:id="@+id/account_dialog_subtitle"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dip"
        android:layout_marginBottom="1dip"
        android:gravity="center"/>

</LinearLayout>